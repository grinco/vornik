  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 316,
      "targets": [
        {
          "expr": "sum(increase(vornik_judge_verdicts_total[24h]))",
          "refId": "A"
        }
      ],
      "title": "Verdicts (24h)",
      "type": "stat",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 317,
      "targets": [
        {
          "expr": "100 * sum(increase(vornik_judge_verdicts_total{verdict=\"pass\"}[24h])) / clamp_min(sum(increase(vornik_judge_verdicts_total[24h])), 1)",
          "refId": "A"
        }
      ],
      "title": "Pass Rate (24h)",
      "type": "stat",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 318,
      "targets": [
        {
          "expr": "sum(increase(vornik_judge_verdicts_total{verdict=\"fail\"}[24h]))",
          "refId": "A"
        }
      ],
      "title": "Fails (24h)",
      "type": "stat",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 319,
      "targets": [
        {
          "expr": "sum(increase(vornik_judge_cost_usd_total[24h]))",
          "refId": "A"
        }
      ],
      "title": "Judge Spend (24h)",
      "type": "stat",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 320,
      "targets": [
        {
          "expr": "sum by (verdict) (rate(vornik_judge_verdicts_total[5m]))",
          "refId": "A",
          "legendFormat": "{{verdict}}"
        }
      ],
      "title": "Verdict Rate by Outcome",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 321,
      "targets": [
        {
          "expr": "sum by (outcome) (rate(vornik_judge_evaluations_total[5m]))",
          "refId": "A",
          "legendFormat": "{{outcome}}"
        }
      ],
      "title": "Evaluation Outcomes (ok / error / skipped / abstain_no_config)",
      "type": "timeseries",
      "description": "The gap between `ok` and `verdicts_total` rate equals `error+abstain_no_config+skipped` \u2014 lets you see judge healthiness at metric time."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 322,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vornik_judge_confidence_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vornik_judge_confidence_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ],
      "title": "Judge Confidence Distribution (p50/p95)",
      "type": "timeseries",
      "description": "Persistently low confidence usually means the rubric is too vague for the task type, or the judge model is undersized."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 323,
      "targets": [
        {
          "expr": "sum by (role, model) (rate(vornik_judge_cost_usd_total[1h]))",
          "refId": "A",
          "legendFormat": "{{role}} / {{model}}"
        }
      ],
      "title": "Judge Spend Rate by Role+Model",
      "type": "timeseries"
    }
  ],
