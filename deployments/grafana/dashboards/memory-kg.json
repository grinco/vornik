      "targets": [
        {
          "expr": "sum by (status) (rate(vornik_memory_graph_chunks_extracted_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "KG Extraction Throughput (chunks/s by outcome)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 226,
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vornik_memory_graph_extraction_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vornik_memory_graph_extraction_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vornik_memory_graph_extraction_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Per-Chunk Extraction Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 227,
      "targets": [
        {
          "expr": "sum by (outcome) (rate(vornik_memory_graph_resolver_decisions_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Resolver Decisions (short_circuit vs llm)",
      "description": "Operators tune the embedding/Levenshtein gate by watching the short_circuit ratio \u2014 it's the single biggest cost lever.",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 228,
      "targets": [
        {
          "expr": "sum by (stage, kind) (rate(vornik_memory_graph_stage_tokens_total[5m]))",
          "legendFormat": "{{stage}} / {{kind}}",
          "refId": "A"
        }
      ],
      "title": "KG Stage Token Rate",
      "description": "Per-stage LLM token consumption. Cost dashboards multiply this by the per-model rate.",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 229,
      "targets": [
        {
          "expr": "rate(vornik_memory_graph_validator_dropped_total[5m])",
          "legendFormat": "validator drops/s",
          "refId": "A"
        },
        {
          "expr": "rate(vornik_memory_graph_same_chunk_dedup_total[5m])",
          "legendFormat": "same-chunk dedup/s",
          "refId": "B"
        },
        {
          "expr": "rate(vornik_memory_graph_dup_key_recovered_total[5m])",
          "legendFormat": "cross-chunk dup recovered/s",
          "refId": "C"
        },
        {
          "expr": "rate(vornik_memory_graph_circuit_tripped_total[5m])",
          "legendFormat": "circuit trips/s",
          "refId": "D"
        }
      ],
      "title": "KG Quality & Recovery Counters",
      "description": "validator drops = below-threshold edges. same-chunk dedup = dup canonical_name in one chunk. cross-chunk recovered = ErrDuplicateKey path on Insert. circuit trips should stay flat.",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
