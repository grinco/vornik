{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Lifetime success rate per role+model from vornik_executor_model_success_rate. Cancelled runs are excluded from the denominator. Low values here combined with high effective-cost identify models that should be swapped out.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.7
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 211,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vornik_executor_model_success_rate",
          "legendFormat": "{{role}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "Success Rate by Role+Model",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Lifetime cost \u00f7 successful step count per role+model from vornik_executor_model_effective_cost_usd. This is $/useful-outcome, not $/attempt. Compare across models running the same role to see which gives the best $ per success.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "orange",
                "value": 1.0
              },
              {
                "color": "red",
                "value": 5.0
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 212,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vornik_executor_model_effective_cost_usd",
          "legendFormat": "{{role}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "Effective $/Success by Role+Model",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Ranked model performance leaderboard. Columns: success rate (higher is better), effective $/success (lower is better), lifetime cost. Sort the effective-cost column to find the cheapest-per-success combos; the success-rate column tells you whether cheap = adequate.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "success rate"
              },
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "effective $/success"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "lifetime cost"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "role"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "model"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 240
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 213,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "effective $/success",
            "desc": false
          }
        ]
      },
      "pluginVersion": "10",
      "targets": [
        {
          "expr": "vornik_executor_model_success_rate",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "vornik_executor_model_effective_cost_usd",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum by (role, model) (vornik_executor_model_cost_usd_total)",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "title": "Model Performance Leaderboard",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "role",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "model 2": true,
              "model 3": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "job 1": true,
              "job 2": true,
              "job 3": true
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "vornik",
    "deep-dive"
  ],
