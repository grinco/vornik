# vornik podman-compose environment.
#
#   cp deployments/podman/.env.example deployments/podman/.env
#   edit deployments/podman/.env
#   podman-compose up -d
#
# Everything with a default (`KEY=default_value`) can be left alone for
# a smoke test. Fields marked REQUIRED must be filled before vornik
# will actually do useful work — the daemon starts either way, but
# task execution will fail without a valid LLM key/endpoint.

# ---------------------------------------------------------------------------
# Host ports (changes which port on the VM forwards to the container).
# ---------------------------------------------------------------------------

# Single-node compose (podman-compose.yaml)
VORNIK_HTTP_PORT=8080
POSTGRES_PORT=5432
# Postgres host-bind interface. Loopback by default so the DB is NOT
# reachable from the LAN; set to 0.0.0.0 only if you genuinely need
# off-host DB access (and firewall it).
POSTGRES_BIND=127.0.0.1

# Role-specialized cluster compose (cluster.compose.yaml).
# Defaults to different ports than the single-node compose so both can
# run on the same host simultaneously.
CLUSTER_POSTGRES_PORT=5433
CLUSTER_POSTGRES_BIND=127.0.0.1
CLUSTER_UI_PORT=8081
CLUSTER_WORKER_API_PORT=8082
CLUSTER_WORKER_RELAY_PORT=8443
CLUSTER_WEBHOOK_PORT=8083

# ---------------------------------------------------------------------------
# PostgreSQL credentials. Anything unique is fine for a demo VM; the
# password is only used between vornik and its private Postgres.
# ---------------------------------------------------------------------------
POSTGRES_DB=vornik
POSTGRES_USER=vornik
POSTGRES_PASSWORD=vornik_dev_password

# ---------------------------------------------------------------------------
# LLM endpoints.
#
# These three env vars drive the `chat:` section of config.yaml — the
# LLM used by the dispatcher and the Telegram bot. The agent containers
# inherit them via `runtime.agent_llm` unless AGENT_LLM_* is set
# separately below.
#
# Examples:
#   Anthropic:  https://api.anthropic.com   + claude-opus-4-7
#   OpenAI:     https://api.openai.com/v1   + gpt-4o
#   Local Ollama: http://host.containers.internal:11434/v1 + qwen2.5:32b
# ---------------------------------------------------------------------------
# REQUIRED:
CHAT_ENDPOINT=https://api.anthropic.com
CHAT_MODEL=claude-opus-4-7
VORNIK_CHAT_API_KEY=

# Optional: separate endpoint for agent containers. Leave empty to
# reuse the chat.* values above (common case).
AGENT_LLM_ENDPOINT=
AGENT_LLM_MODEL=
VORNIK_AGENT_LLM_API_KEY=

# Optional: separate endpoint for the memory/RAG embedding model.
# Leave empty to reuse chat.* (fine for most providers).
VORNIK_EMBEDDING_API_KEY=

# ---------------------------------------------------------------------------
# Telegram bot (optional). Leave empty to disable — vornik's
# dispatcher still works via the HTTP API / UI.
# ---------------------------------------------------------------------------
VORNIK_TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Agent image. Must be pullable by the HOST's podman (since agents
# spawn there, not inside the vornik container).
#
# Local build (fastest for a demo VM — runs on the same host):
#   make build-agent                         # produces vornik-agent:latest
#   AGENT_IMAGE=localhost/vornik-agent:latest
#
# Registry:
#   AGENT_IMAGE=harbor.example.com/vornik-agent:2026.4.20
# ---------------------------------------------------------------------------
AGENT_IMAGE=localhost/vornik-agent:latest

# ---------------------------------------------------------------------------
# Podman socket path on the host. The compose file mounts this into the
# vornik container so the daemon can spawn agents via the HOST's podman.
#
# Rootless (user service — most common demo setup):
#   PODMAN_SOCK=/run/user/$(id -u)/podman/podman.sock
#   -> start the service once: `systemctl --user enable --now podman.socket`
#
# Rootful:
#   PODMAN_SOCK=/run/podman/podman.sock
#   -> `sudo systemctl enable --now podman.socket`
# ---------------------------------------------------------------------------
PODMAN_SOCK=/run/user/1000/podman/podman.sock

# ---------------------------------------------------------------------------
# Build metadata baked into the image (shown on /ui and in /healthz).
# ---------------------------------------------------------------------------
VORNIK_VERSION=dev
VORNIK_BUILD_DATE=
