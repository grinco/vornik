# Vornik daemon environment — HOST install.
#
# Seeded by the quickstart to ~/.config/vornik/vornik.env and loaded by the
# user systemd unit (EnvironmentFile=). These values are expanded into
# ~/.config/vornik/config.yaml via ${VAR} placeholders at daemon startup.
#
# systemd parses simple KEY=value lines (no `export`, no shell quoting).
# After editing: `systemctl --user restart vornik`.
#
# Anything with a default can be left alone for a smoke test. The daemon
# starts without an LLM key, but task execution fails until one is set.

# ---------------------------------------------------------------------------
# PostgreSQL — must match deps.compose.yaml (.env in the checkout). The DB
# is the daemon's durable state and the CE->EE migration anchor.
# ---------------------------------------------------------------------------
POSTGRES_DB=vornik
POSTGRES_USER=vornik
POSTGRES_PORT=5432
VORNIK_DATABASE_PASSWORD=vornik_dev_password

# ---------------------------------------------------------------------------
# Agent run-as user. The quickstart sets this to "$(id -u):$(id -g)" so
# rootless agents can write their bind-mounted workspaces. Match the agent
# image's VORNIK_UID/VORNIK_GID build args.
# ---------------------------------------------------------------------------
VORNIK_RUN_AS_USER=1000:1000

# ---------------------------------------------------------------------------
# LLM endpoint / model for the dispatcher + Telegram bot. Agent containers
# inherit these unless AGENT_LLM_* is set.
#   Anthropic:    https://api.anthropic.com      + claude-opus-4-7
#   OpenAI:       https://api.openai.com/v1       + gpt-4o
#   Local Ollama: http://host.containers.internal:11434/v1 + qwen2.5:32b
# ---------------------------------------------------------------------------
# REQUIRED for task execution:
CHAT_ENDPOINT=https://api.anthropic.com
CHAT_MODEL=claude-opus-4-7
VORNIK_CHAT_API_KEY=

# Optional: separate endpoint for agent containers (reuse chat.* if empty).
AGENT_LLM_ENDPOINT=
AGENT_LLM_MODEL=
VORNIK_AGENT_LLM_API_KEY=

# Optional: separate embedding key for memory/RAG (reuse chat.* if empty).
VORNIK_EMBEDDING_API_KEY=

# ---------------------------------------------------------------------------
# Telegram bot (optional). Empty = disabled; the HTTP API / UI still work.
# ---------------------------------------------------------------------------
VORNIK_TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Agent image. Built into the host's rootless podman storage by the
# quickstart; the daemon spawns it as a sibling container. Must be a
# fully-qualified ref (podman refuses bare short-names non-interactively).
# ---------------------------------------------------------------------------
AGENT_IMAGE=localhost/vornik-agent:latest
